# Contre-Terre — Render environment variables
# Copy these into Render Dashboard > Environment

# Database (embedded FalkorDB — no external service needed)
DATABASE_BACKEND=falkordb
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_GRAPH=contre_terre

# Embedding provider
# "local" uses sentence-transformers (all-mpnet-base-v2, 768d) — no API key needed
# "openai" uses OpenAI API — requires OPENAI_API_KEY
EMBEDDING_PROVIDER=local

# Uncomment for OpenAI embeddings (better quality, requires API key)
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Render flag
RENDER=true
